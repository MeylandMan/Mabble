#version 410 coreout vec4 fragColor;struct Material {	sampler2D diffuse1;	sampler2D specular1;	sampler2D normal1;	sampler2D height1;    float shininess;};uniform Material material;in vec2 v_TexCoords;uniform bool u_NegativeTexCoord;void main(){    /* just using the uniforms so that openGL doesn't PISS ME OF */    float s_temp = material.shininess;    vec4 result = texture(material.diffuse1, v_TexCoords) * texture(material.specular1, v_TexCoords) * texture(material.normal1, v_TexCoords);    if(!u_NegativeTexCoord)        fragColor = texture(material.diffuse1, v_TexCoords);    else        fragColor = texture(material.diffuse1, vec2(v_TexCoords.x, -v_TexCoords.y));}